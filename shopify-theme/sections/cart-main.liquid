<section class="page-hero">
  <div class="page-hero__pattern"></div>
  <div class="page-hero__content container">
    <span class="page-hero__label">Your Order</span>
    <h1 class="page-hero__title">Cart</h1>
  </div>
</section>

<section class="section">
  <div class="container">
    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" class="cart-form">
        <table class="cart-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Total</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {%- for item in cart.items -%}
              <tr class="cart-item" data-animate="fade-up">
                <td class="cart-item__product">
                  <div class="cart-item__inner">
                    {%- if item.image -%}
                      <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title }}" class="cart-item__img" loading="lazy">
                    {%- endif -%}
                    <div>
                      <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                      {%- if item.variant.title != 'Default Title' -%}
                        <p class="cart-item__variant">{{ item.variant.title }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                </td>
                <td class="cart-item__price">{{ item.price | money }}</td>
                <td class="cart-item__quantity">
                  <div class="quantity-selector">
                    <button type="button" class="quantity-selector__btn"
                            onclick="this.parentElement.querySelector('input').stepDown(); this.closest('form').submit();"
                            aria-label="Decrease quantity">−</button>
                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0"
                           class="quantity-selector__input"
                           data-line="{{ forloop.index }}"
                           onchange="this.closest('form').submit();">
                    <button type="button" class="quantity-selector__btn"
                            onclick="this.parentElement.querySelector('input').stepUp(); this.closest('form').submit();"
                            aria-label="Increase quantity">+</button>
                  </div>
                </td>
                <td class="cart-item__total">{{ item.line_price | money }}</td>
                <td class="cart-item__remove">
                  <a href="{{ item.url_to_remove }}" aria-label="Remove {{ item.title }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </a>
                </td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>

        <div class="cart-footer">
          <div class="cart-footer__totals">
            <div class="cart-footer__subtotal">
              <span>Subtotal</span>
              <span class="cart-footer__amount">{{ cart.total_price | money }}</span>
            </div>
            <p class="cart-footer__note">Shipping & taxes calculated at checkout</p>
          </div>
          <button type="submit" name="checkout" class="btn btn--primary cart-footer__checkout">
            Proceed to Checkout
          </button>
        </div>
      </form>

    {%- else -%}
      <div class="cart-empty" data-animate="fade-up">
        <h2>Your cart is empty</h2>
        <p>Looks like you haven't added any ice cream yet!</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary" style="margin-top: var(--space-6);">
          Start Shopping
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
