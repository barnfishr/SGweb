<section class="page-hero">
  <div class="page-hero__pattern"></div>
  <div class="page-hero__content container">
    <h1 class="page-hero__title">{{ page.title }}</h1>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="page-content">
      {{ page.content }}
    </div>
  </div>
</section>

