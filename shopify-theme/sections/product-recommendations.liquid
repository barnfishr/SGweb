{%- if recommendations.performed and recommendations.products_count > 0 -%}
<section class="section featured-flavors" aria-labelledby="rec-heading-{{ section.id }}">
  <div class="container">
    <header class="section-header section-header--center" data-animate="fade-up">
      <span class="section-label">More to Love</span>
      <h2 class="section-title" id="rec-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
    </header>

    <div class="flavors-grid">
      {%- for product in recommendations.products limit: 4 -%}
        <article class="flavor-card" data-animate="fade-up" data-delay="{{ forloop.index | times: 100 }}">
          <a href="{{ product.url }}" class="flavor-card__link">
            <div class="flavor-card__img-wrap">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 400 }}"
                     alt="{{ product.featured_image.alt | default: product.title }}"
                     class="flavor-card__img" loading="lazy">
              {%- endif -%}
            </div>
            <div class="flavor-card__body">
              <h3 class="flavor-card__name">{{ product.title }}</h3>
              <p class="flavor-card__price">{{ product.price | money }}</p>
            </div>
          </a>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Product Recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You Might Also Love"
    }
  ]
}
{% endschema %}
