<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#C0392B">

  <title>
    {%- if page_title -%}{{ page_title }} — {{ shop.name }}{%- else -%}{{ shop.name }}{%- endif -%}
  </title>

  {%- if page_description -%}
  <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {{ 'snelgrove-tokens.css' | asset_url | stylesheet_tag }}
  {{ 'snelgrove-global.css' | asset_url | stylesheet_tag }}
  {{ 'snelgrove-nav.css' | asset_url | stylesheet_tag }}
  {{ 'snelgrove-animations.css' | asset_url | stylesheet_tag }}
  {{ 'snelgrove-shop.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

  {%- if template.name == 'index' -%}
    {{ 'snelgrove-home.css' | asset_url | stylesheet_tag }}
  {%- endif -%}
</head>
<body class="template-{{ template.name }}">

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script>document.getElementById('footer-year').textContent = new Date().getFullYear();</script>
  {{ 'snelgrove-main.js' | asset_url | script_tag }}
</body>
</html>
